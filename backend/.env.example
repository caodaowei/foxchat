# FoxChat 后端环境变量配置
# 复制此文件为 .env 并修改相应值

NODE_ENV=development
PORT=5001
HOST=0.0.0.0

# 数据库连接（开发环境）
DATABASE_URL=postgresql://foxchat:foxchat123@localhost:7801/foxchat

# JWT 配置
JWT_SECRET=foxchat-development-secret-key-min-32-characters
JWT_EXPIRES_IN=7d

# CORS 配置
CORS_ORIGIN=http://localhost:5002
