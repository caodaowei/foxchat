{
  "name": "foxchat-backend",
  "version": "2.0.0",
  "description": "FoxChat 后端 API 服务 - Fastify + PostgreSQL",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
