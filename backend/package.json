    "fastify": "^4.28.0",
    "pg": "^8.12.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^9.0.8",
    "drizzle-kit": "^0.22.0",
